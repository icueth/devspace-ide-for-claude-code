{
  "name": "devspace",
  "type": "module",
  "version": "0.3.26",
  "description": "One-window MacBook dev workspace with Claude Code CLI at the core",
  "license": "MIT",
  "author": {
    "name": "icueth",
    "email": "icueit@gmail.com"
  },
  "main": "dist-electron/main/index.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:mac:arm64": "electron-vite build && electron-builder --mac --arm64",
    "postinstall": "electron-rebuild -f -o node-pty || echo 'node-pty rebuild skipped (terminal will be disabled)'"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-less": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sass": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.1",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/merge": "^6.12.0",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.15",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/sarabun": "^5.2.8",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "diff": "^8.0.3",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.32.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/typography": "^0.5.19",
    "@types/d3": "^7.4.3",
    "@types/diff": "^7.0.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.17",
    "electron": "^40.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9",
    "vite": "^5.4.2"
  },
  "build": {
    "appId": "com.icueth.devspace",
    "productName": "devspace",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/renderer/**",
      "dist-electron/**",
      "package.json",
      "!**/*.map",
      "!**/node_modules/node-pty/prebuilds/win32-*/**",
      "!**/node_modules/node-pty/prebuilds/linux-*/**",
      "!**/node_modules/node-pty/deps/winpty/**",
      "!**/node_modules/node-pty/build/obj.target/**",
      "!**/node_modules/node-pty/build/.deps/**",
      "!**/node_modules/node-pty/build/*.mk",
      "!**/node_modules/node-pty/build/Makefile",
      "!**/node_modules/node-pty/build/binding.Makefile",
      "!**/node_modules/node-pty/build/config.gypi",
      "!**/node_modules/node-pty/build/gyp-mac-tool",
      "!**/node_modules/node-pty/src/**",
      "!**/node_modules/node-pty/scripts/**",
      "!**/node_modules/node-pty/tools/**",
      "!**/*.d.ts",
      "!**/*.md"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "compression": "maximum",
    "electronLanguages": [
      "en"
    ],
    "npmRebuild": false,
    "extraMetadata": {
      "main": "dist-electron/main/index.cjs"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "minimumSystemVersion": "12.0",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "icon": "resources/icon.icns"
    },
    "dmg": {
      "sign": false
    }
  },
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "node-pty"
    ]
  }
}
